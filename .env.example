APP_ENV=local
DATABASE_URL=sqlite:///data/rebootroute.db
MLFLOW_TRACKING_URI=file:./mlruns

# 향후 실제 공공데이터 연동에 사용할 선택 API 키입니다.
# 값이 비어 있으면 MVP는 mock/sample 데이터를 사용하며 실패하지 않습니다.
INCHEON_YOUTH_API_KEY=
INCHEON_CULTURE_API_KEY=
INCHEON_FACILITY_API_KEY=
INCHEON_SUPPORT_API_KEY=
INCHEON_CONTEST_API_KEY=

# 선택: 있으면 대시보드 지도 카드가 내 위치 기준 Google Maps Embed API 경로로 표시됩니다.
# 비어 있으면 공개 Google Maps 장소 embed와 외부 경로 링크를 사용합니다.
GOOGLE_MAPS_API_KEY=
